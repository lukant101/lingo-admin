rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }
    function isValidVideo() {
      return request.resource.size < 500 * 1024 * 1024
        && request.resource.contentType.matches('video/(mp4|quicktime)');
    }
    function isValidImage() {
      return request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }
    function isValidAudio() {
      return request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('audio/(mp4|mpeg|wav)');
    }

    // Platform deck draft — card audio clips
    match /platformDeckDrafts/{uid}/{draftId}/audio/cards/{filename} {
      allow read:  if isOwner(uid) && isAdmin();
      allow write: if isOwner(uid) && isAdmin() && isValidAudio();
    }

    // Platform deck draft — video
    match /platformDeckDrafts/{uid}/{draftId}/video/{filename} {
      allow read:  if isOwner(uid) && isAdmin();
      allow write: if isOwner(uid) && isAdmin() && isValidVideo();
    }

    // Platform deck draft — cover/card images
    match /platformDeckDrafts/{uid}/{draftId}/images/{filename} {
      allow read:  if isOwner(uid) && isAdmin();
      allow write: if isOwner(uid) && isAdmin() && isValidImage();
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
